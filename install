#!/bin/bash

set -o errexit

APT_PACKAGES='
  git
  vim
'

SSH_KEY_FILE="$HOME/.ssh/id_rsa"

SYMLINK_FILES='
  .bash_aliases
  .bash_prompt
  .bashrc
  .gitconfig
  .vimrc
'

script_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null && pwd )"

script_file="$(basename "$0")"
log_file="$script_file.log"

main() {
  create_log_file
  install_apt_packages
  symlink_files
  create_ssh_keys
}

create_log_file() {
  echo "creating log file $log_file"
  > "$log_file"
}

install_apt_packages() {
  echo 'updating apt'
  sudo apt-get update >> "$log_file"

  echo 'upgrading apt packages'
  sudo apt-get upgrade --yes >> "$log_file"
  
  for package in $APT_PACKAGES; do
    if [ "$(is_apt_package_installed "$package")" = 'false' ]; then
      echo "installing $package"
      sudo apt-get install --yes "$package" >> "$log_file"
    else
      echo "($package already installed)"
    fi
  done
}

symlink_files() {
  for file in $SYMLINK_FILES; do
    if [ ! -h "$HOME/$file" ]; then
      if [ -e "$HOME/$file" ]; then
        echo "backing up original $file"
        mv "$HOME/$file" "$HOME/$file.bak"
      fi
      echo "symlinking $file"
      ln --symbolic "$script_dir/$file" "$HOME"
    else
      echo "($file already symlinked)"
    fi
  done
}

create_ssh_keys() {
  if [ ! -e "$SSH_KEY_FILE" ]; then
    echo 'creating ssh keys'
    ssh-keygen -f "$SSH_KEY_FILE" -N '' > /dev/null
  else
    echo '(ssh keys already created)'
  fi
}

is_apt_package_installed() {
  local package="$1"
  dpkg --get-selections | grep "$package\s" > /dev/null
  if [ $? -eq 0 ]; then
    echo 'true'
  else
    echo 'false'
  fi
}

main
